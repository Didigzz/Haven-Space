{
  "name": "haven-space",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "client:dev": "npm run build && npx http-server dist -p 3000 -a localhost -o",
    "client:serve": "npm run build && npx http-server dist -p 3000 -a localhost",
    "client:start": "npm run build && npx http-server dist -p 3000 -a localhost -o",
    "boarder": "node scripts/serve-boarder.js",
    "landlord": "node scripts/serve-landlord.js",
    "server:dev": "php -S localhost:8000 -t server/api",
    "server": "php -S localhost:8000 -t server/api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{html,css,scss,md,json,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8"
  }
}
